# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Okta SAML 2.0
OKTA_SAML_ENTRY_POINT=https://your-org.okta.com/app/your-app-id/sso/saml
OKTA_SAML_ISSUER=http://www.okta.com/your-entity-id
OKTA_SAML_CERT=your-okta-idp-certificate-base64
OKTA_SAML_CALLBACK_URL=http://localhost:3000/api/auth/saml/callback
SAML_SP_ENTITY_ID=td-revenueiq

# Okta SCIM
SCIM_BEARER_TOKEN=your-scim-bearer-token

# Looker
LOOKER_BASE_URL=https://your-instance.looker.com
LOOKER_CLIENT_ID=your-looker-client-id
LOOKER_CLIENT_SECRET=your-looker-client-secret

# Salesforce
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=your-sf-client-id
SALESFORCE_CLIENT_SECRET=your-sf-client-secret
SALESFORCE_USERNAME=your-sf-username
SALESFORCE_PASSWORD=your-sf-password-plus-security-token

# Session
JWT_SECRET=generate-with-openssl-rand-base64-64

# Dev Admin (development only — NEVER set in production)
ENABLE_DEV_ADMIN=true
DEV_ADMIN_PASSWORD=generate-with-openssl-rand-base64-32

# Cron (Vercel Cron or external scheduler)
CRON_SECRET=generate-with-openssl-rand-base64-32

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
